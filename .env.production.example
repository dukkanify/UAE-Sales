# UAE Sales — Production Environment Template
# Configure in Vercel Project Settings → Environment Variables

# Required
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/uae_sales?schema=public&sslmode=require
NEXT_PUBLIC_USE_API=true
NEXT_PUBLIC_APP_URL=https://your-domain.com
SESSION_SECRET=replace-with-64-char-random-secret

# Recommended
NODE_ENV=production

# Optional integrations
NEXT_PUBLIC_API_BASE_URL=
PAYMENT_PROVIDER=mock
STORAGE_PROVIDER=s3
REDIS_URL=
UPSTASH_REDIS_REST_URL=

# Vercel automatically sets VERCEL_URL — map to NEXT_PUBLIC_APP_URL in dashboard
