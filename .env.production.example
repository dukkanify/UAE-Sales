# Stripe (live mode keys from https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CURRENCY=aed

# Production canonical URL (required at build time)
NEXT_PUBLIC_APP_URL=https://sooqna.site

# Session cookie — share across apex and www (www redirects to apex)
SESSION_COOKIE_DOMAIN=.sooqna.site

# Optional — external API
NEXT_PUBLIC_API_BASE_URL=
