# Stripe (test mode keys from https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CURRENCY=aed

# Local development URL (Stripe redirect URLs)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Session cookie domain — leave empty for localhost
SESSION_COOKIE_DOMAIN=

# Optional — external API (not required for Stripe checkout)
NEXT_PUBLIC_API_BASE_URL=

# Feature flags
NEXT_PUBLIC_ENABLE_UAE_PASS=false
NEXT_PUBLIC_ENABLE_EMAIL_OTP=false
NEXT_PUBLIC_ENABLE_GUEST_CHECKOUT=true

# Email / OTP
EMAIL_PROVIDER=resend
EMAIL_FROM_NAME=Sooqna
EMAIL_FROM_ADDRESS=no-reply@sooqna.site
RESEND_API_KEY=
OTP_EXPIRY_MINUTES=10
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_PEPPER=sooqna-dev-pepper
ENABLE_DEMO_OTP=true
PASSWORD_PEPPER=sooqna-dev-password-pepper
