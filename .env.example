# UAE Sales — Local Development Environment
# Copy to `.env` and adjust values.

# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/uae_sales?schema=public"

# Enable API/DB mode (required for production auth middleware)
NEXT_PUBLIC_USE_API=false

# Public app URL (used for CSRF origin checks and SEO canonical URLs)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional external API base (leave empty when using same-origin /api routes)
NEXT_PUBLIC_API_BASE_URL=

# Session signing secret (min 32 chars) — required in production
SESSION_SECRET=dev-only-change-me-to-32-char-secret

# Payment provider placeholder (stripe|checkout|mock)
PAYMENT_PROVIDER=mock

# Storage provider placeholder (local|s3|cloudinary)
STORAGE_PROVIDER=local

# Optional Redis/Upstash URL for distributed rate limiting
# REDIS_URL=
# UPSTASH_REDIS_REST_URL=
