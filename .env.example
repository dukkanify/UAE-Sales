# Stripe (test mode keys from https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CURRENCY=aed

# Local development URL (Stripe redirect URLs)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Session cookie domain — leave empty for localhost
SESSION_COOKIE_DOMAIN=

# Optional — external API (not required for Stripe checkout)
NEXT_PUBLIC_API_BASE_URL=
