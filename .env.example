# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/uae_sales?schema=public"

# Enable API mode for client auth (optional — mock mode works without DB)
NEXT_PUBLIC_USE_API="false"

# External API base URL (optional — leave empty for same-origin /api routes)
# NEXT_PUBLIC_API_BASE_URL=""

# Session security (change in production)
SESSION_SECRET="change-me-in-production"
